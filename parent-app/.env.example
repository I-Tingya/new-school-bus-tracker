# Parent App Configuration
# This file contains environment variables for the Parent App

# Backend API Configuration
# For emulator: http://10.0.2.2:4000 (Android)
# For real device: http://192.168.1.X:4000 (replace with your IP)
# For production: https://your-api-domain.com:4000
EXPO_PUBLIC_API_URL=http://10.0.2.2:4000

# Google Maps API Key
# Get your key from: https://console.cloud.google.com
# Required for the embedded map and ETA calculations
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Location Tracking Polling Interval
# How often to check for active trips (milliseconds, default 10000 = 10 seconds)
EXPO_PUBLIC_TRIP_POLL_INTERVAL=10000

# ETA Update Interval
# How often to refresh ETA calculation (milliseconds, default 30000 = 30 seconds)
EXPO_PUBLIC_ETA_REFRESH_INTERVAL=30000

# Debug logging (set to true for development)
EXPO_PUBLIC_DEBUG=false
